# Simple rename: OLD_FEATURE_ENABLE -> FEATURE_ENABLE
CONFIG_OLD_FEATURE_ENABLE CONFIG_FEATURE_ENABLE
# Rename with different types
CONFIG_OLD_SPEED CONFIG_FEATURE_SPEED
CONFIG_OLD_NAME CONFIG_FEATURE_NAME
CONFIG_OLD_ADDR CONFIG_FEATURE_ADDR
# Inversion: OLD_FEATURE_DISABLE (inverted) -> FEATURE_ENABLE
CONFIG_INVERTED_ENABLE !CONFIG_FEATURE_DISABLE
# Another inversion
CONFIG_INVERTED_ANOTHER !CONFIG_ANOTHER_BOOL
# New name absent from Kconfig (undefined-new-symbol test)
CONFIG_GHOST_OLD CONFIG_GHOST_NEW
